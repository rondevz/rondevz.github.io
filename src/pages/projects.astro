---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import ButtonLink from "../components/ButtonLink.astro";
import { contributedProjects } from "../data/projects";
import Services from "../components/home/Services.astro";
---

<Layout>
  <main class="text-gray-200 w-full h-full overflow-x-hidden">
    <div class="mt-24 mb-36 lg:mt-28 lg:mb-40">
      <div class="section-kicker mb-4">Portfolio</div>
      <h1 class="relative text-3xl md:text-5xl text-left max-w-3xl font-black mb-6 text-white">
        Engineering <span class="text-pink-400">Solutions</span>
      </h1>
      
      <p class="text-lg text-left text-slate-400 mb-16 max-w-3xl leading-relaxed">
        A selection of software products and contributions where I focused on architecture, performance, and long-term maintainability.
      </p>

      <section class="mb-20">
        <h2 class="text-2xl font-bold mb-6 flex items-center text-slate-100">
          <span class="text-pink-400 mr-2 font-code">></span><span>Open Source & Contributions</span>
        </h2>
        <p class="text-slate-400 mb-8">Projects built in collaborative environments with product and engineering impact.</p>
        
        <ProjectsGrid projects={contributedProjects} />
      </section>

      <Services id="services" class="mb-36 lg:mb-40" />
    </div>
  </main>
</Layout>
