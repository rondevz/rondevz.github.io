---
import { Image } from "astro:assets";
import { cn } from "../utils";
import ButtonLink from "./ButtonLink.astro";
import InteractiveHeadline from "./InteractiveHeadline";
const { class: className } = Astro.props;
---

<div class={cn("relative flex items-center w-full min-h-[74vh]", className)}>
	<div class="relative z-10 max-w-7xl mx-auto px-2 sm:px-4 lg:px-8 w-full">
		<div
			class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_22rem] xl:grid-cols-[minmax(0,1fr)_24rem] gap-8 lg:gap-14 items-center">
			<div class="order-1 flex flex-col items-start text-left max-w-2xl">
				<span class="section-kicker mb-6">
					<span class="size-1.5 rounded-full bg-pink-300"></span>
					Software Engineer
				</span>

				<InteractiveHeadline client:load />

				<p class="text-lg md:text-xl text-slate-300 mb-5 max-w-xl leading-relaxed">
					Hi, I am <span class="font-semibold text-white">Ronald Pereira</span>
					(<span class="font-code text-pink-300">rondevz</span>) - an adaptable engineer who ships
					high-quality products from idea to production.
				</p>

				<p class="text-base text-slate-400 mb-7 max-w-xl leading-relaxed">
					I work across web, mobile, desktop, and game development with the same mindset: clear architecture,
					thoughtful UX, and reliable delivery.
				</p>

				<p
					class="mb-8 text-[11px] sm:text-xs font-code uppercase tracking-[0.18em] text-slate-400 leading-relaxed">
					PHP & Laravel • React Ecosystem • Cross Platform • Game Dev Journey
				</p>

				<div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
					<ButtonLink href="/projects" variant="primary" class="min-w-42">View My Work</ButtonLink>
					<ButtonLink href="#services" variant="secondary" class="min-w-42">Start a Project</ButtonLink>
				</div>

				<p
					class="mt-5 text-xs text-slate-500 italic hover:text-pink-300 transition-colors cursor-help hidden md:block"
					title="It's the best one, fight me.">
					(Yes, I like Dark Souls 2)
				</p>
			</div>

			<div class="order-2 flex justify-center lg:justify-end">
				<div
					class="relative w-56 h-56 sm:w-72 sm:h-72 lg:w-[22rem] lg:h-[22rem] xl:w-[24rem] xl:h-[24rem] group">
					<div
						class="absolute inset-0 border border-pink-400/30 rounded-[2rem] translate-x-3 translate-y-3 transition-transform duration-300 group-hover:translate-x-2 group-hover:translate-y-2">
					</div>

					<div class="absolute inset-0 panel rounded-[2rem] overflow-hidden shadow-2xl shadow-black/40">
						<Image
							src="https://avatars.githubusercontent.com/u/41125008?v=4"
							alt="Ronald Pereira"
							class="w-full h-full object-cover object-center opacity-92 group-hover:opacity-100 transition-opacity duration-500"
							width={400}
							height={400}
							loading="eager"
						/>
						<div
							class="absolute inset-0 bg-linear-to-t from-[#0f1622]/70 via-transparent to-transparent opacity-75">
						</div>
						<div
							class="absolute bottom-0 left-0 right-0 px-5 py-4 bg-linear-to-t from-black/60 to-transparent text-left">
							<p class="text-sm font-code text-slate-200">rondevz</p>
							<p class="text-xs text-slate-400">Building software that scales with ideas.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
