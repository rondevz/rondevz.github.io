---
import type { HTMLAttributes } from "astro/types";

type Variant = "primary" | "secondary" | "tertiary";

type Props = HTMLAttributes<"a"> & {
    variant?: Variant;
};

const { href, class: className, variant = "primary", ...props } = Astro.props as Props;

const baseClasses =
	"px-8 py-3 rounded-xl text-white font-semibold tracking-wide transition-all hover:-translate-y-0.5 text-center border";

const variantClasses: Record<Variant, string> = {
	primary: "bg-pink-600/95 hover:bg-pink-500 border-pink-400/40 shadow-lg shadow-pink-900/30",
	secondary: "bg-white/5 hover:bg-white/10 border-white/12 text-slate-200",
	tertiary: "bg-transparent hover:bg-white/6 border-white/14 text-slate-200",
};
---

<a href={href} 
    class:list={[
        className,
        baseClasses,
        variantClasses[variant],
    ]}
    {...props}>
    <slot></slot>
</a>
